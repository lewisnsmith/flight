{
  "name": "flight-proxy",
  "version": "1.0.0",
  "description": "MCP flight recorder and token optimizer for AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "flight": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.test.json",
    "bench": "npx tsx bench/throughput.ts",
    "check": "npm run lint && npm run typecheck && npm run test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "proxy",
    "ai",
    "claude",
    "debugging",
    "observability",
    "hallucination",
    "tool-calling",
    "flight-recorder"
  ],
  "author": "Lewis Smith",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
